pkgdir=[patch-2.8]
pkgname=[patch]
pkgver=[2.8]
pkgrel=[1]
zarchive=[false]

pkgurl=[https://ftp.gnu.org/gnu/patch/patch-2.8.tar.xz]
md5sum=[149327a021d41c8f88d034eab41c039f]

extract=[ xtar $LFS/sources/patch-2.8.tar.xz ]

prepare=[ ./configure --prefix=/usr --host=$LFS_TGT --build=$(build-aux/config.guess) ]

build=[ make ]

install=[ make DESTDIR=$LFS install ]

clean=[ cd ../ && rm -rf patch-2.8 ]
